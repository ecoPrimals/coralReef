// GLSL 450 compute: workgroup shared-memory parallel reduction.
// Exercises: shared memory, barrier, power-of-two stride reduction, atomics.
#version 450

layout(local_size_x = 256) in;

layout(std430, binding = 0) buffer InBuf   { float input_data[]; };
layout(std430, binding = 1) buffer OutBuf  { float partial_sums[]; };

shared float sdata[256];

void main() {
    uint tid = gl_LocalInvocationID.x;
    uint gid = gl_GlobalInvocationID.x;
    uint wgid = gl_WorkGroupID.x;

    sdata[tid] = input_data[gid];
    barrier();

    for (uint stride = 128u; stride > 0u; stride >>= 1u) {
        if (tid < stride) {
            sdata[tid] += sdata[tid + stride];
        }
        barrier();
    }

    if (tid == 0u) {
        partial_sums[wgid] = sdata[0];
    }
}
