# SPDX-License-Identifier: AGPL-3.0-only
# coralReef udev rules for VFIO device management
#
# Both Titan V GPUs (10de:1d81) are claimed by vfio-pci at module load
# time via modprobe options (ids=10de:1d81). These udev rules handle
# post-bind setup: power pinning, reset disabling, and permissions.
#
# The RTX 5060 (10de:2d05 @ 21:00.0) is unaffected — nvidia binds it.
#
# Install:
#   sudo cp scripts/boot/99-coralreef-vfio.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules

# ── Power Management ─────────────────────────────────────────
# Keep both Titan V's in D0 (prevent runtime PM from D3hot transitions)
ACTION=="add", KERNEL=="0000:03:00.0", SUBSYSTEM=="pci", ATTR{vendor}=="0x10de", ATTR{device}=="0x1d81", ATTR{power/control}="on"
ACTION=="add", KERNEL=="0000:4a:00.0", SUBSYSTEM=="pci", ATTR{vendor}=="0x10de", ATTR{device}=="0x1d81", ATTR{power/control}="on"

# ── Reset Method Disabling ───────────────────────────────────
# Disable destructive bus reset (preserves HBM2 state across rebind)
ACTION=="add", KERNEL=="0000:03:00.0", SUBSYSTEM=="pci", RUN+="/bin/sh -c 'echo > /sys/bus/pci/devices/0000:03:00.0/reset_method 2>/dev/null || true'"
ACTION=="add", KERNEL=="0000:4a:00.0", SUBSYSTEM=="pci", RUN+="/bin/sh -c 'echo > /sys/bus/pci/devices/0000:4a:00.0/reset_method 2>/dev/null || true'"

# ── Audio Function Binding ───────────────────────────────────
# Audio functions must also be in vfio-pci (same IOMMU group)
ACTION=="add", KERNEL=="0000:03:00.1", SUBSYSTEM=="pci", ATTR{vendor}=="0x10de", RUN+="/bin/sh -c 'echo vfio-pci > /sys/bus/pci/devices/0000:03:00.1/driver_override 2>/dev/null || true'"
ACTION=="add", KERNEL=="0000:4a:00.1", SUBSYSTEM=="pci", ATTR{vendor}=="0x10de", RUN+="/bin/sh -c 'echo vfio-pci > /sys/bus/pci/devices/0000:4a:00.1/driver_override 2>/dev/null || true'"

# ── Permissions ──────────────────────────────────────────────
# VFIO container and group devices — allow coralreef service user
KERNEL=="vfio", MODE="0666"
SUBSYSTEM=="vfio", MODE="0666"

# Per-device sysfs permissions for coral-glowplug hot-swap operations
ACTION=="add|change", SUBSYSTEM=="pci", KERNEL=="0000:03:00.0", ATTR{vendor}=="0x10de", ATTR{device}=="0x1d81", \
  RUN+="/bin/chmod 0666 /sys/bus/pci/devices/0000:03:00.0/driver_override", \
  RUN+="/bin/chmod 0666 /sys/bus/pci/devices/0000:03:00.0/config", \
  RUN+="/bin/chmod 0666 /sys/bus/pci/devices/0000:03:00.0/resource0"

ACTION=="add|change", SUBSYSTEM=="pci", KERNEL=="0000:4a:00.0", ATTR{vendor}=="0x10de", ATTR{device}=="0x1d81", \
  RUN+="/bin/chmod 0666 /sys/bus/pci/devices/0000:4a:00.0/driver_override", \
  RUN+="/bin/chmod 0666 /sys/bus/pci/devices/0000:4a:00.0/config", \
  RUN+="/bin/chmod 0666 /sys/bus/pci/devices/0000:4a:00.0/resource0"
